# Old drafts
attic/

# Binary document formats (MD versions tracked instead)
*.odt
*.docx
*.pdf

# PDFs in bibliography (keep .bib only)
content/bibliography/*.pdf

# Machine-specific data path (see .env.example)
.env

# Data directory — DVC manages catalog/pool/exports/syllabi (*.dvc files tracked by git)
data/raw/
data/run_reports/
data/teaching_sources.yaml
data/catalogs/.citations_batch_checkpoint.csv
# Phase-2 derived data (analysis intermediates + derived tables) — regenerable,
# not a writing deliverable, not DVC-tracked. Split by dataflow phase from
# data/catalogs/ so the directory names the owning phase (tickets 0208, 0219).
data/derived/

# Make sentinel files (dynamic-output targets)
*.stamp

# Generated figures, tables, and stats (regenerate with: make figures / make stats).
# The manuscript's writing-facing deliverables (small, byte-stable PNGs + table)
# are git-tracked like content/_includes/ so a clean-room writing build (manuscript.mk)
# needs no Phase-1 data. Everything else under figures/ and tables/ stays ignored
# (bulk analysis intermediates — ticket 0131).
content/figures/*
!content/figures/fig_bars_v1.png
!content/figures/fig_composition.png
!content/figures/fig_breaks.png
content/tables/*
!content/tables/tab_venues.md
!content/tables/tab_venues_fr.md
!content/tables/tab_venues_fr_caption.md
# A.5 pre-2007 separation is cited number-by-number in the manuscript prose;
# commit its generator output so every cited value has an archived record (ticket 0161).
!content/tables/tab_null_separation_pre2007.csv
!content/tables/tab_pre2007_coverage.csv
content/*-vars.yml
!content/manuscript-vars.yml

# Python / uv
.venv
__pycache__/
*.pyc
.mypy_cache/
.ruff_cache/
.pytest_cache/
# Per-test durations recorded by the fast-path ratchet (ticket 0216) — a
# machine/run-specific artifact regenerated on every `make check`.
.test_durations.json
.cache/

# Replication archive
*.tar.gz

# DOI-fetch stub (real tool lives at ~/CNRS/code/DOI-fetch/)
code/doifetch/

# Quarto build artifacts and HTML test renders
.quarto/
output/
*.html
*_files/
**/*.quarto_ipynb

# LaTeX build artifacts (generated by Quarto → PDF rendering)
*.aux
*.log
content/*.tex

# OS and editor artifacts
.DS_Store
*~
*.swp

# Claude Code config — track shared config, ignore local/user files
.claude/*
!.claude/rules/
!.claude/skills/
!.claude/hooks/
!.claude/settings.json
.claude/settings.local.json

/.quarto/
_variables.yml
benchmarks/

beat-log.jsonl

# git-erg compiled binary
tickets/erg
