# Old drafts
attic/

# Binary document formats (MD versions tracked instead)
*.odt
*.docx
*.pdf

# PDFs in bibliography (keep .bib only)
deliverables/_shared/bibliography/*.pdf

# Machine-specific data path (see .env.example)
.env

# Data directory — DVC manages catalog/pool/exports/syllabi (*.dvc files tracked by git)
data/raw/
data/teaching_sources.yaml
data/catalogs/.citations_batch_checkpoint.csv
# Phase-2 derived data (analysis intermediates + derived tables) — regenerable,
# not a writing deliverable, not DVC-tracked. Split by dataflow phase from
# data/catalogs/ so the directory names the owning phase (tickets 0208, 0219).
data/derived/

# Make sentinel files (dynamic-output targets)
*.stamp

# Generated figures, tables, and stats (regenerate with: make figures / make stats).
# The manuscript's writing-facing deliverables (small, byte-stable PNGs + table)
# are git-tracked like deliverables/_shared/_includes/ so a clean-room writing
# build (manuscript.mk) needs no Phase-1 data. Everything else under figures/ and
# tables/ stays ignored (bulk analysis intermediates — tickets 0131, 0226).
deliverables/_shared/figures/*
!deliverables/_shared/figures/fig_bars_v1.png
!deliverables/_shared/figures/fig_composition.png
!deliverables/_shared/figures/fig_breaks.png
# Citer-limited traditions network: potential electronic supplement of the
# data paper (R1-14, ticket 0286) — committed artifact, not embedded in a doc.
!deliverables/_shared/figures/fig_traditions_pre2008_citers.png
# Companion artifact of the data-paper global map (ticket 0307): produced by
# make, committed for reference, NOT embedded in any deliverable.
!deliverables/_shared/figures/fig_global_map_cocitation.png
# Data-paper semantic-composition figure (ticket 0310): the manuscript's
# thematic-recomposition figure recomputed on the current corpus.
!deliverables/_shared/figures/fig_sem_composition.png
deliverables/_shared/tables/*
!deliverables/_shared/tables/tab_variables.md
!deliverables/_shared/tables/codebook.md
!deliverables/_shared/tables/tab_venues.md
!deliverables/_shared/tables/tab_venues_fr.md
!deliverables/_shared/tables/tab_venues_fr_caption.md
# A.5 pre-2007 separation is cited number-by-number in the manuscript prose;
# commit its generator output so every cited value has an archived record (ticket 0161).
!deliverables/_shared/tables/tab_null_separation_pre2007.csv
!deliverables/_shared/tables/tab_pre2007_coverage.csv
# tab_corpus_sources.csv is a writing deliverable grouped with tab_corpus_sources.md
# (produced by the same export_corpus_table.py target); it stays in the shared
# tables dir, not evicted to $(DERIVED) — declared here so the class guard treats
# it as a deliverable, not a Phase-2 intermediate (ticket 0218).
!deliverables/_shared/tables/tab_corpus_sources.csv
# Per-document reference-count distribution is cited number-by-number in the
# data paper (RDJ-26561 referee remark R1-13); commit its generator output so
# every quoted value has an archived record (ticket 0285).
!deliverables/_shared/tables/tab_reference_counts.csv
# R1-14 limitations demonstration: every number in the response letter's
# network paragraph traces to these artifacts (ticket 0286).
!deliverables/_shared/tables/tab_network_limitations.csv
!deliverables/_shared/tables/qa_cocitation_edges_report.json
# Dedup error-rate estimates are quoted in the data paper's dedup discussion
# (R1-12, ticket 0301 → 0276); commit the artifact for the same reason.
!deliverables/_shared/tables/tab_dedup_error_estimates.csv
# Literature confirmations quoted in the data paper's review bullets
# (ED-02/R1-18, ticket 0310); commit the artifacts so every quoted statistic
# has an archived, deterministic record.
!deliverables/_shared/tables/tab_lit_confirmations.csv
!deliverables/_shared/tables/tab_semantic_robustness.csv
!deliverables/_shared/tables/tab_sem6_assignments.csv
!deliverables/_shared/tables/tab_sem_composition.csv
# Generated -vars.yml, each in its deliverable folder (ticket 0226); the
# manuscript's is pinned to v1.0 values and stays git-tracked.
deliverables/_shared/technical-report-vars.yml
deliverables/data-paper/data-paper-vars.yml
deliverables/multilayer/multilayer-detection-vars.yml
!deliverables/manuscript/manuscript-vars.yml

