# Project configuration for git-erg.
# Created by: erg init

[labels]
# Label vocabulary -- one per line. All labels suppress `erg ready` output.
# Remove or add lines to fit your workflow.
needs-human
deferred

[update]
# Git remote (name or URL) that `erg update` fetches the committed binary from.
# Defaults to "origin" -- you update from where you cloned. Point it at upstream
# to track upstream's binary instead, e.g.:
# url = https://github.com/MinhHaDuong/git-erg.git
